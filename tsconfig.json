{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "jsx": "preserve",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": ["vite/client"]
  },
  "include": [
    "src/**/*",
    "src/vite-env.d.ts",
    ".storybook/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
